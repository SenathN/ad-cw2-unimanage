@model UniManage.Models.ViewModels.SystemReportViewModel
@{
    ViewData["Title"] = "System Reports";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="fas fa-chart-bar me-2 text-primary"></i>System Overview Report</h1>
        <button class="btn btn-outline-primary" onclick="window.print()">
            <i class="fas fa-print me-1"></i> Print Report
        </button>
    </div>

    <!-- Stats Cards -->
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card bg-primary text-white h-100 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title mb-0">Total Students</h6>
                            <h2 class="display-6 fw-bold mb-0">@Model.TotalStudents</h2>
                        </div>
                        <i class="fas fa-user-graduate fa-2x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white h-100 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title mb-0">Total Courses</h6>
                            <h2 class="display-6 fw-bold mb-0">@Model.TotalCourses</h2>
                        </div>
                        <i class="fas fa-book fa-2x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white h-100 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title mb-0">Total Assignments</h6>
                            <h2 class="display-6 fw-bold mb-0">@Model.TotalAssignments</h2>
                        </div>
                        <i class="fas fa-tasks fa-2x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-white h-100 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title mb-0">Total Submissions</h6>
                            <h2 class="display-6 fw-bold mb-0">@Model.TotalSubmissions</h2>
                        </div>
                        <i class="fas fa-file-upload fa-2x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- User Distribution -->
        <div class="col-lg-4">
            <div class="card h-100 shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="card-title mb-0">User Distribution</h5>
                </div>
                <div class="card-body">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span><i class="fas fa-user-graduate me-2 text-primary"></i>Students</span>
                            <span class="badge bg-primary rounded-pill">@Model.TotalStudents</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span><i class="fas fa-user-tie me-2 text-success"></i>Lecturers</span>
                            <span class="badge bg-success rounded-pill">@Model.TotalLecturers</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span><i class="fas fa-user-shield me-2 text-danger"></i>Administrators</span>
                            <span class="badge bg-danger rounded-pill">@Model.TotalAdministrators</span>
                        </li>
                    </ul>
                    <div class="mt-4 text-center">
                        <p class="text-muted small mb-0">Total Registered Users</p>
                        <h4 class="fw-bold">@(Model.TotalStudents + Model.TotalLecturers + Model.TotalAdministrators)</h4>
                    </div>
                </div>
            </div>
        </div>

        <!-- Top Enrolled Courses -->
        <div class="col-lg-8">
            <div class="card h-100 shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="card-title mb-0">Top 5 Enrolled Courses</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Course Name</th>
                                    <th class="text-center">Enrollments</th>
                                    <th>Trend</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var course in Model.TopEnrolledCourses)
                                {
                                    <tr>
                                        <td>@course.CourseName</td>
                                        <td class="text-center fw-bold">@course.EnrollmentCount</td>
                                        <td style="width: 200px;">
                                            @{
                                                var percentage = Model.TotalEnrollments > 0 ? (course.EnrollmentCount * 100 / Model.TotalEnrollments) : 0;
                                            }
                                            <div class="progress" style="height: 8px;">
                                                <div class="progress-bar bg-success" role="progressbar" style="width: @percentage%"></div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Lecturer Performance -->
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="card-title mb-0">Lecturer Activity Overview</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Lecturer Name</th>
                                    <th class="text-center">Courses Managed</th>
                                    <th class="text-center">Assignments Created</th>
                                    <th class="text-center">Average Load</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var lecturer in Model.LecturerPerformance)
                                {
                                    <tr>
                                        <td class="fw-bold">@lecturer.LecturerName</td>
                                        <td class="text-center">
                                            <span class="badge bg-info">@lecturer.CourseCount Courses</span>
                                        </td>
                                        <td class="text-center">
                                            <span class="badge bg-secondary">@lecturer.AssignmentCount Assignments</span>
                                        </td>
                                        <td class="text-center text-muted small">
                                            @(lecturer.CourseCount > 0 ? Math.Round((double)lecturer.AssignmentCount / lecturer.CourseCount, 1) : 0) assignments/course
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        @@media print {
            .navbar, .footer, .btn, .alert {
                display: none !important;
            }
            .container-fluid {
                padding: 0 !important;
            }
            .card {
                border: 1px solid #dee2e6 !important;
                box-shadow: none !important;
            }
            .bg-primary, .bg-success, .bg-info, .bg-warning {
                background-color: #fff !important;
                color: #000 !important;
                border: 1px solid #dee2e6 !important;
            }
            .text-white {
                color: #000 !important;
            }
            .opacity-50 {
                display: none;
            }
        }
    </style>
}
