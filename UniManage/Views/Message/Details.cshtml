@model UniManage.Models.Message
@{
    ViewData["Title"] = "Message Details";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">@Model.Subject</h5>
                    <a asp-action="Index" class="btn btn-sm btn-outline-light">
                        <i class="fas fa-arrow-left me-1"></i>Back to Messages
                    </a>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-sm-2 text-muted">From:</div>
                        <div class="col-sm-10 font-weight-bold">
                            @Model.Sender.FirstName @Model.Sender.LastName (@Model.Sender.Email)
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-2 text-muted">To:</div>
                        <div class="col-sm-10">
                            @Model.Receiver.FirstName @Model.Receiver.LastName (@Model.Receiver.Email)
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-2 text-muted">Date:</div>
                        <div class="col-sm-10">
                            @Model.SentAt.ToString("MMMM dd, yyyy HH:mm")
                        </div>
                    </div>
                    <hr />
                    <div class="message-content p-3 bg-light rounded" style="white-space: pre-wrap;">
                        @Model.Content
                    </div>
                </div>
                <div class="card-footer bg-white d-flex justify-content-end">
                    <div class="btn-group">
                        @if (Model.ReceiverId == (string?)ViewBag.CurrentUserId || Model.ReceiverId == Model.Receiver.Id) {
                            // The controller sets ViewBag.CurrentUserId in Index, but not in Details.
                            // However, we can check if the current user is the receiver.
                            // In Details action, we already verified permissions.
                        }
                        
                        <a asp-action="Reply" asp-route-id="@Model.Id" class="btn btn-primary">
                            <i class="fas fa-reply me-1"></i>Reply
                        </a>
                        
                        <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this message?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger">
                                <i class="fas fa-trash me-1"></i>Delete
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
