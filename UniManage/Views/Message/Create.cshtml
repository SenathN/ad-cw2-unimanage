@model UniManage.Models.ViewModels.CreateMessageViewModel
@{
    var isReply = !string.IsNullOrEmpty(ViewBag.RecipientName);
    ViewData["Title"] = isReply ? "Reply to Message" : "Compose Message";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="fas @(isReply ? "fa-reply" : "fa-pen") me-2"></i>
                        @ViewData["Title"]
                    </h5>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        
                        <div class="mb-3">
                            <label asp-for="ReceiverId" class="form-label"></label>
                            @if (isReply)
                            {
                                <input type="hidden" asp-for="ReceiverId" />
                                <input type="text" class="form-control" value="@ViewBag.RecipientName" readonly />
                            }
                            else
                            {
                                <select asp-for="ReceiverId" class="form-select" asp-items="ViewBag.Recipients">
                                    <option value="">-- Select Recipient --</option>
                                </select>
                            }
                            <span asp-validation-for="ReceiverId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Subject" class="form-label"></label>
                            <input asp-for="Subject" class="form-control" placeholder="Enter subject" />
                            <span asp-validation-for="Subject" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Content" class="form-label"></label>
                            <textarea asp-for="Content" class="form-control" rows="10" placeholder="Type your message here..."></textarea>
                            <span asp-validation-for="Content" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-paper-plane me-1"></i>Send Message
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
