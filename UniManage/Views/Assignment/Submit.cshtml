@model UniManage.Models.ViewModels.SubmitAssignmentViewModel
@{
    ViewData["Title"] = "Submit Assignment";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">Submit Assignment</h3>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        <strong>Academic Integrity Warning:</strong> This submission will be checked for plagiarism. Ensure all work is your own original content. Copying from other sources or students will result in disciplinary action.
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <h5>Assignment Details</h5>
                            <p><strong>Title:</strong> @Model.AssignmentTitle</p>
                            <p><strong>Course:</strong> @Model.CourseTitle</p>
                            <p><strong>Due Date:</strong> @Model.DueDate.ToString("MMMM dd, yyyy HH:mm")</p>
                            <p><strong>Max Points:</strong> @Model.MaxPoints</p>
                            @if (Model.IsLate)
                            {
                                <p class="text-danger"><strong>Status:</strong> Late Submission</p>
                            }
                        </div>
                        <div class="col-md-6">
                            <div class="card bg-light">
                                <div class="card-body">
                                    <h6><i class="fas fa-shield-alt me-2"></i>Submission Guidelines</h6>
                                    <ul class="small mb-0">
                                        <li>Submit only your own original work</li>
                                        <li>Properly cite all sources</li>
                                        <li>Avoid direct copying from online resources</li>
                                        <li>Use proper paraphrasing techniques</li>
                                        <li>Include references where applicable</li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>

                    <form method="post" id="submissionForm">
                        <div asp-validation-summary="All" class="text-danger"></div>
                        <input type="hidden" asp-for="AssignmentId" />
                        
                        <div class="form-group mb-3">
                            <label asp-for="Content" class="form-label">
                                <i class="fas fa-edit me-2"></i>Assignment Content
                            </label>
                            <textarea asp-for="Content" 
                                      class="form-control" 
                                      rows="12" 
                                      id="submissionContent"
                                      placeholder="Enter your assignment content here..."></textarea>
                            <span asp-validation-for="Content" class="text-danger"></span>
                            <small class="form-text text-muted">
                                <i class="fas fa-info-circle me-1"></i>
                                Minimum 100 characters required. Content will be analyzed for originality.
                            </small>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <div class="card bg-light">
                                    <div class="card-body">
                                        <h6><i class="fas fa-chart-line me-2"></i>Content Analysis</h6>
                                        <div id="contentStats">
                                            <p class="mb-1"><strong>Word Count:</strong> <span id="wordCount">0</span></p>
                                            <p class="mb-1"><strong>Character Count:</strong> <span id="charCount">0</span></p>
                                            <p class="mb-0"><strong>Estimated Reading Time:</strong> <span id="readTime">0 min</span></p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="card @(Model.IsLate ? "bg-danger text-white" : "bg-success text-white")">
                                    <div class="card-body">
                                        <h6><i class="fas fa-clock me-2"></i>Submission Status</h6>
                                        @if (Model.IsLate)
                                        {
                                            <p class="mb-0"><strong>Late Submission!</strong></p>
                                            <p class="mb-0 small">This submission will be marked as late.</p>
                                        }
                                        else
                                        {
                                            <p class="mb-0"><strong>On Time Submission</strong></p>
                                            <p class="mb-0 small">Submit before the deadline for full credit.</p>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="alert alert-info">
                            <i class="fas fa-lock me-2"></i>
                            <strong>Plagiarism Detection:</strong> Your submission will be automatically checked against:
                            <ul class="mb-0 mt-2">
                                <li>Previous student submissions</li>
                                <li>Online academic databases</li>
                                <li>Published literature and websites</li>
                                <li>Internal university resources</li>
                            </ul>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary" id="submitBtn">
                                <i class="fas fa-paper-plane me-2"></i>Submit Assignment
                            </button>
                            <a href="@Url.Action("Index")" class="btn btn-secondary">
                                <i class="fas fa-times me-2"></i>Cancel
                            </a>
                            <button type="button" class="btn btn-outline-info" id="saveDraftBtn">
                                <i class="fas fa-save me-2"></i>Save Draft
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const contentTextarea = document.getElementById('submissionContent');
            const wordCountSpan = document.getElementById('wordCount');
            const charCountSpan = document.getElementById('charCount');
            const readTimeSpan = document.getElementById('readTime');
            const submitBtn = document.getElementById('submitBtn');
            const saveDraftBtn = document.getElementById('saveDraftBtn');

            // Prevent copy/paste functionality
            contentTextarea.addEventListener('paste', function(e) {
                e.preventDefault();
                alert('Copy/paste is disabled for academic integrity purposes.');
                return false;
            });

            contentTextarea.addEventListener('drop', function(e) {
                e.preventDefault();
                alert('Drag and drop is disabled for academic integrity purposes.');
                return false;
            });

            // Content analysis
            function updateContentStats() {
                const content = contentTextarea.value;
                const words = content.trim().split(/\s+/).filter(word => word.length > 0);
                const wordCount = words.length;
                const charCount = content.length;
                const readTime = Math.ceil(wordCount / 200); // Average reading speed: 200 words/min

                wordCountSpan.textContent = wordCount;
                charCountSpan.textContent = charCount;
                readTimeSpan.textContent = readTime + ' min';

                // Enable/disable submit button based on minimum requirements
                if (charCount < 100) {
                    submitBtn.disabled = true;
                    submitBtn.textContent = 'Minimum 100 characters required';
                } else {
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = '<i class="fas fa-paper-plane me-2"></i>Submit Assignment';
                }

                // Auto-save draft
                localStorage.setItem('assignmentDraft_' + @Model.AssignmentId, content);
            }

            contentTextarea.addEventListener('input', updateContentStats);

            // Load draft if exists
            const savedDraft = localStorage.getItem('assignmentDraft_' + @Model.AssignmentId);
            if (savedDraft) {
                contentTextarea.value = savedDraft;
                updateContentStats();
            }

            // Save draft button
            saveDraftBtn.addEventListener('click', function() {
                localStorage.setItem('assignmentDraft_' + @Model.AssignmentId, contentTextarea.value);
                alert('Draft saved locally!');
            });

            // Clear draft on successful submission
            document.getElementById('submissionForm').addEventListener('submit', function() {
                localStorage.removeItem('assignmentDraft_' + @Model.AssignmentId);
            });

            // Initial stats update
            updateContentStats();
        });
    </script>
}
