@model IEnumerable<UniManage.Models.Course>
@{
    ViewData["Title"] = "Browse Courses";
}

<div class="container">
    <div class="row">
        <div class="col-12">
            <h2 class="mb-4">Available Courses</h2>
            @if (!User.Identity?.IsAuthenticated == true)
            {
                <div class="alert alert-info">
                    <i class="fas fa-info-circle me-2"></i>
                    Please <a href="@Url.Action("Login", "Account")" class="alert-link">login</a> or <a href="@Url.Action("Register", "Account")" class="alert-link">register</a> to enroll in courses.
                </div>
            }
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="row">
            @foreach (var course in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <span class="badge bg-primary">@course.CourseCode</span>
                            <span class="badge bg-success">@course.Credits Credits</span>
                        </div>
                        <div class="card-body">
                            <h5 class="card-title">@course.Title</h5>
                            <p class="card-text text-muted small">
                                Instructor: @course.Lecturer.FirstName @course.Lecturer.LastName
                            </p>
                            <p class="card-text">
                                @(course.Description.Length > 150 ? course.Description.Substring(0, 150) + "..." : course.Description)
                            </p>
                            
                            @if (course.Prerequisites.Any())
                            {
                                <div class="mb-2">
                                    <small class="text-muted">
                                        <strong>Prerequisites:</strong>
                                        <ul class="list-unstyled mb-0">
                                            @foreach (var prereq in course.Prerequisites)
                                            {
                                                <li>· @prereq.PrerequisiteCourse.CourseCode - @prereq.PrerequisiteCourse.Title</li>
                                            }
                                        </ul>
                                    </small>
                                </div>
                            }

                            <div class="d-flex justify-content-between align-items-center mt-auto">
                                <small class="text-muted">
                                    <i class="fas fa-users me-1"></i>
                                    @course.CurrentEnrollment/@course.MaxEnrollment enrolled
                                </small>
                                <div class="progress" style="width: 100px; height: 8px;">
                                    <div class="progress-bar" style="width: @(course.CurrentEnrollment * 100 / course.MaxEnrollment)%"></div>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer">
                            <a href="@Url.Action("Details", new { id = course.Id })" class="btn btn-primary btn-sm">View Details</a>
                            @if (User.IsInRole("Student"))
                            {
                                <span class="ms-2">
                                    <a href="@Url.Action("Details", new { id = course.Id })" class="btn btn-success btn-sm">Enroll Now</a>
                                </span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="fas fa-book fa-3x text-muted mb-3"></i>
            <h4 class="text-muted">No courses available</h4>
            <p class="text-muted">Check back later for new course offerings.</p>
        </div>
    }
</div>
