@model IEnumerable<UniManage.Models.Course>
@{
    ViewData["Title"] = "Course Management";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2>Course Management</h2>
                <a asp-action="Create" class="btn btn-primary">
                    <i class="fas fa-plus"></i> Create New Course
                </a>
            </div>

            <div class="card">
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Code</th>
                                    <th>Title</th>
                                    <th>Lecturer</th>
                                    <th>Enrollment</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var course in Model)
                                {
                                    <tr>
                                        <td>@course.CourseCode</td>
                                        <td>@course.Title</td>
                                        <td>@(course.Lecturer != null ? $"{course.Lecturer.FirstName} {course.Lecturer.LastName}" : "Not Assigned")</td>
                                        <td>@course.CurrentEnrollment / @course.MaxEnrollment</td>
                                        <td>
                                            @if (course.IsActive)
                                            {
                                                <span class="badge bg-success">Active</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">Inactive</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="btn-group btn-group-sm">
                                                <a asp-action="Details" asp-route-id="@course.Id" class="btn btn-outline-info">
                                                    <i class="fas fa-info-circle"></i> Details
                                                </a>
                                                <a asp-action="Edit" asp-route-id="@course.Id" class="btn btn-outline-primary">
                                                    <i class="fas fa-edit"></i> Edit
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
